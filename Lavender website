<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8" />
<meta name="viewport" content="width=device-width, initial-scale=1.0" />
<title>Lavender Meadow — Athlete · Artist · Earth</title>
<link href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,400;0,700;1,400;1,600&family=Cormorant+Garamond:ital,wght@0,300;0,400;0,500;1,300;1,400&family=Jost:wght@200;300;400;500&display=swap" rel="stylesheet" />
<style>
  :root {
    --cream:#F6F1E9; --warm-white:#FDFAF5; --parchment:#EDE5D6;
    --sand:#D9CBAF; --tan:#C4AC8A; --lavender:#9B8FBB;
    --lavender-deep:#7A6E9A; --lavender-pale:#EAE5F4; --lavender-mist:#F2EFF9;
    --sage:#8FA685; --sage-light:#B9CCAF; --sage-pale:#ECF3E9;
    --earth:#6B5844; --bark:#3A2D1E; --blush:#E8D5C8; --moss:#5A6E50;
  }
  *,*::before,*::after{margin:0;padding:0;box-sizing:border-box}
  html{scroll-behavior:smooth}
  body{background:var(--warm-white);color:var(--bark);font-family:'Jost',sans-serif;font-weight:300;overflow-x:hidden}
  .cursor{width:10px;height:10px;background:var(--lavender);border-radius:50%;position:fixed;pointer-events:none;z-index:9999;transform:translate(-50%,-50%);transition:transform .15s ease}
  .cursor-ring{width:36px;height:36px;border:1.5px solid var(--lavender);border-radius:50%;position:fixed;pointer-events:none;z-index:9998;transform:translate(-50%,-50%);opacity:.5;transition:width .3s,height .3s}
  nav{position:fixed;top:0;left:0;right:0;z-index:200;padding:1.5rem 4rem;display:flex;justify-content:space-between;align-items:center;background:rgba(253,250,245,.88);backdrop-filter:blur(18px);border-bottom:1px solid rgba(212,196,168,.35)}
  .nav-logo{font-family:'Playfair Display',serif;font-size:1.05rem;letter-spacing:.06em;color:var(--bark);text-decoration:none}
  .nav-logo em{font-style:italic;color:var(--lavender)}
  .nav-links{display:flex;gap:2.5rem;list-style:none}
  .nav-links a{font-size:.7rem;letter-spacing:.18em;text-transform:uppercase;color:var(--earth);text-decoration:none;font-weight:400;position:relative;padding-bottom:2px;transition:color .25s}
  .nav-links a::after{content:'';position:absolute;bottom:0;left:0;width:0;height:1px;background:var(--lavender);transition:width .3s ease}
  .nav-links a:hover{color:var(--lavender)}
  .nav-links a:hover::after{width:100%}
  .nav-cta{padding:.6rem 1.6rem;background:var(--lavender);color:#fff;border-radius:999px;font-size:.68rem;letter-spacing:.14em;text-transform:uppercase;text-decoration:none;font-weight:400;transition:all .25s}
  .nav-cta:hover{background:var(--lavender-deep);transform:translateY(-1px);box-shadow:0 6px 20px rgba(122,110,154,.3)}
  .lang-toggle{display:flex;align-items:center;gap:.35rem;padding:.45rem 1rem;border-radius:999px;border:1.5px solid var(--sand);background:transparent;font-family:'Jost',sans-serif;font-size:.68rem;letter-spacing:.12em;text-transform:uppercase;color:var(--earth);cursor:pointer;transition:all .25s;font-weight:400}
  .lang-toggle:hover{border-color:var(--lavender);color:var(--lavender)}
  .nav-right{display:flex;align-items:center;gap:1rem}
  #hero{min-height:100vh;display:grid;grid-template-columns:1.05fr .95fr;padding-top:82px;position:relative;overflow:hidden;background:var(--warm-white)}
  .bg-blob{position:absolute;border-radius:50%;pointer-events:none;filter:blur(80px);opacity:.45}
  .blob-1{width:600px;height:600px;background:var(--lavender-mist);top:-120px;right:-120px}
  .blob-2{width:400px;height:400px;background:var(--sage-pale);bottom:-80px;left:0}
  .blob-3{width:300px;height:300px;background:var(--blush);top:40%;left:35%;opacity:.3}
  .hero-left{display:flex;flex-direction:column;justify-content:center;padding:5rem 3.5rem 5rem 4.5rem;position:relative;z-index:2}
  .hero-eyebrow{display:flex;align-items:center;gap:.8rem;margin-bottom:1.8rem;opacity:0;animation:fadeUp .8s .1s ease both}
  .eyebrow-line{width:36px;height:1px;background:var(--lavender)}
  .eyebrow-text{font-size:.68rem;letter-spacing:.22em;text-transform:uppercase;color:var(--lavender);font-weight:400}
  .hero-heading{opacity:0;animation:fadeUp .8s .25s ease both;margin-bottom:1.6rem}
  .hero-heading h1{font-family:'Playfair Display',serif;font-size:clamp(3.4rem,5.5vw,5.8rem);line-height:.95;color:var(--bark);font-weight:400}
  .hero-heading h1 em{font-style:italic;color:var(--lavender);display:block}
  .hero-sub{font-family:'Cormorant Garamond',serif;font-size:1.22rem;font-style:italic;color:var(--earth);line-height:1.65;max-width:420px;opacity:0;animation:fadeUp .8s .4s ease both;margin-bottom:2.2rem}
  .hero-values{display:flex;flex-wrap:wrap;gap:.55rem;margin-bottom:2.8rem;opacity:0;animation:fadeUp .8s .52s ease both}
  .val-chip{padding:.32rem .95rem;border-radius:999px;font-size:.66rem;letter-spacing:.1em;text-transform:uppercase;border:1px solid;transition:all .22s;cursor:default}
  .val-chip:hover{transform:translateY(-2px)}
  .vc-lav{border-color:var(--lavender);color:var(--lavender);background:var(--lavender-mist)}
  .vc-sage{border-color:var(--sage);color:var(--moss);background:var(--sage-pale)}
  .vc-tan{border-color:var(--tan);color:var(--earth);background:var(--parchment)}
  .vc-blush{border-color:#CBAA98;color:var(--earth);background:var(--blush)}
  .hero-cta{display:flex;gap:1rem;flex-wrap:wrap;opacity:0;animation:fadeUp .8s .64s ease both}
  .btn{display:inline-flex;align-items:center;gap:.5rem;padding:.88rem 2.2rem;border-radius:999px;font-family:'Jost',sans-serif;font-size:.72rem;letter-spacing:.12em;text-transform:uppercase;text-decoration:none;font-weight:400;transition:all .28s;cursor:pointer;border:none}
  .btn-primary{background:var(--lavender);color:#fff}
  .btn-primary:hover{background:var(--lavender-deep);transform:translateY(-3px);box-shadow:0 12px 30px rgba(122,110,154,.32)}
  .btn-ghost{background:transparent;color:var(--earth);border:1.5px solid var(--sand)}
  .btn-ghost:hover{border-color:var(--lavender);color:var(--lavender);transform:translateY(-3px)}
  .hero-right{position:relative;z-index:2;display:flex;align-items:center;justify-content:center;padding:3rem 3rem 3rem 1rem}
  .photo-container{position:relative;opacity:0;animation:fadeIn 1.1s .3s ease both;margin:0 5rem}
  .photo-frame{width:420px;max-width:100%;aspect-ratio:4/5;border-radius:50% 50% 46% 46%/48% 48% 42% 42%;overflow:hidden;box-shadow:0 40px 100px rgba(58,45,30,.12),0 0 0 1px rgba(201,180,154,.2);position:relative;transition:transform .5s ease}
  .photo-frame:hover{transform:scale(1.015)}
  .photo-frame img{width:100%;height:100%;object-fit:cover;object-position:center top;display:block}
  .badge-float{position:absolute;background:var(--warm-white);border:1px solid var(--sand);border-radius:14px;padding:.9rem 1.1rem;box-shadow:0 8px 28px rgba(58,45,30,.09);z-index:3}
  .badge-1{left:-4.5rem;top:18%;animation:floatA 5s ease-in-out infinite}
  .badge-2{right:-4.5rem;bottom:22%;animation:floatB 6s ease-in-out infinite}
  .badge-inner{display:flex;align-items:center;gap:.6rem}
  .badge-icon{font-size:1.3rem}
  .badge-text-top{font-size:.58rem;letter-spacing:.1em;text-transform:uppercase;color:var(--tan)}
  .badge-text-main{font-size:.82rem;font-weight:500;color:var(--bark)}
  .scroll-hint{position:absolute;bottom:2.5rem;left:50%;transform:translateX(-50%);display:flex;flex-direction:column;align-items:center;gap:.5rem;opacity:0;animation:fadeIn 1s 1.2s ease both}
  .scroll-hint span{font-size:.62rem;letter-spacing:.18em;text-transform:uppercase;color:var(--tan)}
  .scroll-line{width:1px;height:48px;background:linear-gradient(to bottom,var(--lavender),transparent);animation:scrollPulse 2s ease-in-out infinite}
  section{padding:8rem 5rem}
  .sec-label{display:flex;align-items:center;gap:.7rem;margin-bottom:1rem}
  .sec-label-line{width:28px;height:1px;background:var(--lavender)}
  .sec-label span{font-size:.66rem;letter-spacing:.22em;text-transform:uppercase;color:var(--lavender);font-weight:400}
  .sec-title{font-family:'Playfair Display',serif;font-size:clamp(2rem,3.8vw,3.4rem);color:var(--bark);font-weight:400;line-height:1.08;margin-bottom:1.4rem}
  .sec-title em{font-style:italic;color:var(--lavender)}
  .sec-rule{width:52px;height:1.5px;background:linear-gradient(90deg,var(--lavender),var(--sage));margin-bottom:2.8rem}
  #about{background:var(--cream);display:grid;grid-template-columns:1fr 1fr;gap:6rem;align-items:center}
  .about-body p{font-family:'Cormorant Garamond',serif;font-size:1.16rem;line-height:1.9;color:var(--earth);margin-bottom:1.4rem}
  .about-aside{display:flex;flex-direction:column;gap:1.1rem}
  .value-card{background:var(--warm-white);border:1px solid rgba(212,196,168,.6);border-radius:18px;padding:1.5rem 1.4rem;display:flex;align-items:flex-start;gap:1rem;transition:all .3s ease;position:relative;overflow:hidden}
  .value-card::before{content:'';position:absolute;inset:0;background:linear-gradient(135deg,var(--lavender-mist),transparent);opacity:0;transition:opacity .3s}
  .value-card:hover{transform:translateX(6px);border-color:var(--lavender)}
  .value-card:hover::before{opacity:1}
  .vc-icon{font-size:1.5rem;flex-shrink:0;margin-top:.1rem}
  .vc-body{position:relative;z-index:1}
  .vc-body h4{font-family:'Playfair Display',serif;font-size:.95rem;font-weight:600;color:var(--bark);margin-bottom:.25rem}
  .vc-body p{font-size:.78rem;color:var(--earth);line-height:1.6;opacity:.85}
  #gallery{background:var(--warm-white);padding:8rem 5rem}
  .gallery-header{display:flex;justify-content:space-between;align-items:flex-end;margin-bottom:3.5rem;flex-wrap:wrap;gap:2rem}
  .gallery-grid{display:grid;grid-template-columns:repeat(4,1fr);gap:1.2rem}
  .gallery-item{border-radius:16px;overflow:hidden;background:var(--parchment);aspect-ratio:3/4;transition:all .35s ease;display:flex;align-items:flex-end;position:relative;border:1px solid rgba(212,196,168,.4)}
  .gallery-item:first-child{grid-row:span 2;aspect-ratio:auto}
  .gallery-item:hover{transform:scale(1.02);box-shadow:0 20px 50px rgba(58,45,30,.12)}
  .gallery-item img{position:absolute;inset:0;width:100%;height:100%;object-fit:cover;object-position:center}
  .gallery-item.pos-top img{object-position:top center}
  .gi-label{position:absolute;bottom:1rem;left:1rem;right:1rem;font-size:.65rem;letter-spacing:.1em;text-transform:uppercase;color:#fff;opacity:.9;z-index:2;text-shadow:0 1px 4px rgba(0,0,0,.6)}
  #design{background:var(--cream)}
  .design-intro p{font-family:'Cormorant Garamond',serif;font-size:1.16rem;line-height:1.85;color:var(--earth);max-width:560px}
  .design-layout{display:grid;grid-template-columns:.85fr 1.15fr;gap:4.5rem;margin-top:4rem;align-items:start}
  .service-cards{display:flex;flex-direction:column;gap:1rem}
  .service-card{border:1px solid rgba(212,196,168,.6);border-radius:16px;padding:1.4rem 1.5rem;display:flex;align-items:center;gap:1.2rem;background:var(--warm-white);cursor:pointer;transition:all .25s}
  .service-card:hover,.service-card.active{border-color:var(--lavender);background:var(--lavender-mist)}
  .sc-icon{font-size:1.4rem;flex-shrink:0}
  .sc-info h4{font-size:.88rem;font-weight:500;color:var(--bark);margin-bottom:.2rem}
  .sc-info p{font-size:.74rem;color:var(--earth);opacity:.75;line-height:1.5}
  .sc-arrow{margin-left:auto;color:var(--lavender);font-size:.8rem;opacity:0;transition:opacity .2s}
  .service-card:hover .sc-arrow{opacity:1}
  .request-form{display:flex;flex-direction:column;gap:1.1rem}
  .request-form h3{font-family:'Playfair Display',serif;font-size:1.4rem;color:var(--bark);margin-bottom:.5rem}
  .form-row{display:grid;grid-template-columns:1fr 1fr;gap:1rem}
  .fg{display:flex;flex-direction:column;gap:.4rem}
  .fg label{font-size:.66rem;letter-spacing:.14em;text-transform:uppercase;color:var(--earth);opacity:.75;font-weight:400}
  .fg input,.fg select,.fg textarea{padding:.78rem 1rem;border:1.5px solid var(--sand);border-radius:11px;background:var(--warm-white);font-family:'Jost',sans-serif;font-size:.84rem;font-weight:300;color:var(--bark);outline:none;resize:vertical;transition:border-color .22s,box-shadow .22s}
  .fg input:focus,.fg select:focus,.fg textarea:focus{border-color:var(--lavender);box-shadow:0 0 0 4px rgba(155,143,187,.1)}
  .budget-label{font-size:.66rem;letter-spacing:.14em;text-transform:uppercase;color:var(--earth);opacity:.75;margin-bottom:.5rem}
  .budget-pills{display:flex;flex-wrap:wrap;gap:.5rem}
  .bp{padding:.38rem .95rem;border-radius:999px;border:1.5px solid var(--sand);background:transparent;font-family:'Jost',sans-serif;font-size:.73rem;color:var(--earth);cursor:pointer;transition:all .2s}
  .bp:hover,.bp.sel{border-color:var(--lavender);background:var(--lavender-mist);color:var(--lavender-deep)}
  #work{background:var(--warm-white)}
  .work-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:2rem;margin-top:3.5rem}
  .work-card{border-radius:20px;overflow:hidden;background:var(--cream);border:1px solid rgba(212,196,168,.5);transition:all .35s ease}
  .work-card:hover{transform:translateY(-6px);box-shadow:0 24px 60px rgba(58,45,30,.1)}
  .work-card-img{aspect-ratio:4/3;overflow:hidden;background:var(--parchment)}
  .work-card-img img{width:100%;height:100%;object-fit:cover;object-position:center;transition:transform .4s ease}
  .work-card:hover .work-card-img img{transform:scale(1.04)}
  .work-card-body{padding:1.4rem 1.5rem}
  .work-tag{font-size:.6rem;letter-spacing:.12em;text-transform:uppercase;color:var(--sage);margin-bottom:.4rem}
  .work-card-body h4{font-family:'Playfair Display',serif;font-size:1rem;font-weight:400;color:var(--bark);margin-bottom:.5rem}
  .work-card-body p{font-size:.76rem;color:var(--earth);line-height:1.65;opacity:.82}
  #merch{background:var(--cream)}
  .merch-intro p{font-family:'Cormorant Garamond',serif;font-size:1.16rem;line-height:1.85;color:var(--earth);max-width:580px;margin-bottom:3.5rem}
  .collab-strip{background:var(--bark);border-radius:22px;padding:3rem 3.5rem;display:flex;justify-content:space-between;align-items:center;gap:2rem;flex-wrap:wrap;margin-bottom:3.5rem;position:relative;overflow:hidden}
  .collab-strip::before{content:'🌿';position:absolute;right:3rem;top:-1rem;font-size:8rem;opacity:.05;pointer-events:none}
  .collab-strip h3{font-family:'Playfair Display',serif;font-size:1.7rem;color:var(--cream);font-weight:400;margin-bottom:.6rem}
  .collab-strip h3 em{font-style:italic;color:var(--lavender-pale)}
  .collab-strip p{color:var(--tan);font-size:.88rem;line-height:1.65;max-width:440px}
  .btn-cream{background:var(--cream);color:var(--bark);white-space:nowrap}
  .btn-cream:hover{background:var(--parchment);transform:translateY(-3px);box-shadow:0 10px 28px rgba(0,0,0,.18)}
  .merch-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:1.6rem}
  .merch-card{border-radius:20px;overflow:hidden;background:var(--warm-white);border:1px solid rgba(212,196,168,.5);transition:all .35s ease;cursor:pointer}
  .merch-card:hover{transform:translateY(-8px);box-shadow:0 24px 60px rgba(58,45,30,.12)}
  .merch-img{aspect-ratio:1;display:flex;align-items:center;justify-content:center;font-size:4rem;position:relative;overflow:hidden;background:linear-gradient(135deg,var(--lavender-pale),var(--parchment))}
  .merch-img img{position:absolute;inset:0;width:100%;height:100%;object-fit:cover;object-position:center}
  .merch-details{padding:1.3rem 1.4rem}
  .partner-tag{font-size:.62rem;letter-spacing:.12em;text-transform:uppercase;color:var(--sage);margin-bottom:.3rem;font-weight:400}
  .merch-details h4{font-size:.9rem;font-weight:400;color:var(--bark);margin-bottom:.3rem}
  .merch-price{font-family:'Cormorant Garamond',serif;font-size:1.05rem;color:var(--lavender-deep)}
  .eco-note{display:flex;align-items:center;gap:.3rem;font-size:.64rem;color:var(--sage);margin-top:.5rem}
  #partners{background:var(--cream);padding:5rem 5rem;text-align:center}
  .partner-line{font-size:.66rem;letter-spacing:.2em;text-transform:uppercase;color:var(--tan);margin-bottom:2.5rem}
  .partner-row{display:flex;justify-content:center;align-items:center;flex-wrap:wrap;gap:2.5rem}
  .partner-slot{padding:.75rem 2rem;border:1px dashed var(--sand);border-radius:10px;font-size:.7rem;letter-spacing:.1em;text-transform:uppercase;color:var(--tan);min-width:130px;text-align:center;transition:all .2s}
  .partner-slot:hover{border-color:var(--sage);color:var(--sage)}
  #contact{background:var(--bark);padding:9rem 5rem 5rem;text-align:center;position:relative;overflow:hidden}
  #contact::before{content:'';position:absolute;inset:0;background:radial-gradient(ellipse at 50% 0%,rgba(155,143,187,.12) 0%,transparent 60%);pointer-events:none}
  .contact-inner{position:relative;z-index:1}
  #contact .sec-label span{color:var(--lavender-pale)}
  #contact .sec-label-line{background:var(--lavender-pale)}
  #contact .sec-title{color:var(--cream)}
  #contact .sec-rule{background:linear-gradient(90deg,var(--lavender-pale),var(--sage-light));margin:0 auto 2.5rem}
  #contact .contact-sub{font-family:'Cormorant Garamond',serif;font-size:1.22rem;font-style:italic;color:var(--tan);max-width:480px;margin:0 auto 3.5rem;line-height:1.7}
  .contact-links{display:flex;justify-content:center;gap:1rem;flex-wrap:wrap;margin-bottom:6rem}
  .c-link{padding:.82rem 2rem;border-radius:999px;border:1px solid rgba(196,172,138,.3);color:var(--tan);text-decoration:none;font-size:.72rem;letter-spacing:.12em;text-transform:uppercase;font-weight:400;transition:all .25s}
  .c-link:hover{border-color:var(--lavender-pale);color:var(--lavender-pale);transform:translateY(-2px)}
  .footer-bottom{border-top:1px solid rgba(196,172,138,.15);padding-top:2.5rem;display:flex;justify-content:space-between;align-items:center;flex-wrap:wrap;gap:1rem}
  .footer-logo{font-family:'Playfair Display',serif;font-size:.95rem;color:var(--cream);opacity:.5}
  .footer-logo em{font-style:italic;color:var(--lavender-pale);opacity:1}
  .footer-copy{font-size:.68rem;color:var(--tan);opacity:.4;letter-spacing:.06em}
  .eco-badge-footer{display:flex;align-items:center;gap:.35rem;font-size:.66rem;color:var(--sage-light);opacity:.6;letter-spacing:.08em;text-transform:uppercase}
  @keyframes fadeUp{from{opacity:0;transform:translateY(26px)}to{opacity:1;transform:translateY(0)}}
  @keyframes fadeIn{from{opacity:0}to{opacity:1}}
  @keyframes floatA{0%,100%{transform:translateY(0px) rotate(-1deg)}50%{transform:translateY(-12px) rotate(1deg)}}
  @keyframes floatB{0%,100%{transform:translateY(0px) rotate(1deg)}50%{transform:translateY(-8px) rotate(-1deg)}}
  @keyframes scrollPulse{0%,100%{opacity:.4}50%{opacity:1}}
  .reveal{opacity:0;transform:translateY(22px);transition:opacity .8s ease,transform .8s ease}
  .reveal.visible{opacity:1;transform:translateY(0)}
  @media(max-width:900px){
    nav{padding:1.2rem 2rem}
    .nav-links{display:none}
    #hero{grid-template-columns:1fr}
    .hero-left{padding:4rem 2rem}
    .hero-right{padding:0 2rem 4rem}
    .photo-frame{width:300px}
    .badge-1,.badge-2{display:none}
    section{padding:5rem 2rem}
    #about{grid-template-columns:1fr;gap:3rem}
    .design-layout{grid-template-columns:1fr;gap:3rem}
    .merch-grid{grid-template-columns:1fr 1fr}
    .work-grid{grid-template-columns:1fr 1fr}
    .gallery-grid{grid-template-columns:1fr 1fr}
    .gallery-item:first-child{grid-row:span 1;aspect-ratio:3/4}
  }
</style>
</head>
<body>

<div class="cursor" id="cur"></div>
<div class="cursor-ring" id="curRing"></div>

<nav>
  <a href="#" class="nav-logo"><em>Lavender</em> Meadow ✦</a>
  <ul class="nav-links">
    <li><a href="#about" data-en="About" data-fr="À Propos">About</a></li>
    <li><a href="#gallery" data-en="Gallery" data-fr="Galerie">Gallery</a></li>
    <li><a href="#work" data-en="Portfolio" data-fr="Portfolio">Portfolio</a></li>
    <li><a href="#design" data-en="Design" data-fr="Design">Design</a></li>
    <li><a href="#merch" data-en="Shop" data-fr="Boutique">Shop</a></li>
    <li><a href="#contact" data-en="Contact" data-fr="Contact">Contact</a></li>
  </ul>
  <div class="nav-right">
    <button class="lang-toggle" id="langBtn" onclick="toggleLang()">🇫🇷 FR</button>
    <a href="#design" class="nav-cta" data-en="Request a Design" data-fr="Demander un Design">Request a Design</a>
  </div>
</nav>

<!-- ═══════════════════════════════════════════════════════════════
     HERO SECTION
═══════════════════════════════════════════════════════════════ -->
<section id="hero">
  <div class="bg-blob blob-1"></div>
  <div class="bg-blob blob-2"></div>
  <div class="bg-blob blob-3"></div>
  <div class="hero-left">
